# Anthropic API key used by agent-forge to generate projects.
ANTHROPIC_API_KEY=

# Optional: override the default model (default: claude-opus-4-5).
# AGENT_FORGE_MODEL=claude-opus-4-5

# Optional: default path to your local agent-deployments repo.
# AGENT_FORGE_DEPLOYMENTS_PATH=/absolute/path/to/agent-deployments

# Optional: override the cache root (default: ~/.cache/agent-forge).
# Used for the failures/ subdirectory where malformed LLM responses are saved.
# AGENT_FORGE_CACHE_DIR=~/.cache/agent-forge

# Optional: override the TOML config path (default: ~/.config/agent-forge/config.toml).
# AGENT_FORGE_CONFIG_PATH=~/.config/agent-forge/config.toml
